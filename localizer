# Main entry point
main() {
    local command="$1"
    local path="$2"

    case "$command" in
        process)
            cmd_process "$path"
            ;;
        chat)
            cmd_chat "$path"
            ;;
        speak)
            cmd_speak "$path"
            ;;
        record)
            cmd_record
            ;;
        reply)
            cmd_reply
            ;;
        setup)
            cmd_setup
            ;;
        help|--help|-h)
            show_help
            ;;
        *)
            show_help
            exit 1
            ;;
    esac
}

main "$@"
